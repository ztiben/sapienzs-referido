PAYLOAD_SECRET=changeme-generate-a-random-secret

# Vercel Postgres / Neon connection string
POSTGRES_URL=postgres://postgres:postgres@127.0.0.1:5432/sapyenzs_referido

# Set to "true" ONLY for the first deploy (or fresh DB) so Payload auto-creates
# the schema. Leave unset/false afterwards and use migrations before launch.
PAYLOAD_DB_PUSH=

# Vercel Blob read-write token (media uploads)
BLOB_READ_WRITE_TOKEN=

COMPANY_NAME="Sapyenzs Referido"
SITE_NAME="Sapyenzs Referido"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret
