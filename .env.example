PAYLOAD_SECRET=mygeneratedsecret
DATABASE_URL=mongodb://127.0.0.1/template-ecommerce

COMPANY_NAME="Payload Inc."
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Payload Commerce"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Used to preview drafts
PREVIEW_SECRET=demo-draft-secret

# MercadoPago Checkout Pro credentials
# Access token: Tus integraciones > Credenciales (use TEST credentials in dev)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-
# Webhook secret: Tus integraciones > Webhooks > Clave secreta
MERCADOPAGO_WEBHOOK_SECRET=

# Storefront brand to display on cardholder statements (max 22 chars)
COMPANY_NAME="Acme Inc."

# App license selects which world(s) to enable: products | services | both
APP_LICENSE_TYPE=products

# WhatsApp Cloud API (Meta) — developers.facebook.com > Your App > WhatsApp > API Setup
# Permanent access token (System User) or temporary token for dev
WHATSAPP_ACCESS_TOKEN=
# "Phone number ID" of the sending number (NOT the phone number itself)
WHATSAPP_PHONE_NUMBER_ID=
# Any string you choose; must match the "Verify token" configured in the webhook setup
WHATSAPP_VERIFY_TOKEN=
# App Secret: Your App > App Settings > Basic > App Secret (used to verify X-Hub-Signature-256)
WHATSAPP_APP_SECRET=
