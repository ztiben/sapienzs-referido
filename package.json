{
  "name": "sapyenzs-referido",
  "version": "1.0.0",
  "description": "Sapyenzs Referido — curated affiliate deals site (Payload + Next.js)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" payload migrate && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "seed:pages": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts NODE_OPTIONS='--no-deprecation --import=tsx/esm' tsx src/infrastructure/scripts/seed-pages.script.ts",
    "seed:retailers": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts NODE_OPTIONS='--no-deprecation --import=tsx/esm' tsx src/infrastructure/scripts/seed-retailers.script.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.75.0",
    "@payloadcms/db-vercel-postgres": "3.75.0",
    "@payloadcms/email-nodemailer": "3.75.0",
    "@payloadcms/live-preview-react": "3.75.0",
    "@payloadcms/next": "3.75.0",
    "@payloadcms/plugin-form-builder": "3.75.0",
    "@payloadcms/plugin-seo": "3.75.0",
    "@payloadcms/richtext-lexical": "3.75.0",
    "@payloadcms/storage-vercel-blob": "3.75.0",
    "@payloadcms/translations": "3.75.0",
    "@payloadcms/ui": "3.75.0",
    "@radix-ui/react-accordion": "1.2.11",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^8.2.0",
    "embla-carousel-auto-scroll": "^8.1.5",
    "embla-carousel-react": "^8.5.2",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "0.563.0",
    "next": "15.4.11",
    "next-intl": "^4.8.3",
    "next-themes": "0.4.6",
    "payload": "3.75.0",
    "prism-react-renderer": "^2.3.1",
    "qs-esm": "^7",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.2",
    "sonner": "^1.7.2",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@next/eslint-plugin-next": "^15.5.4",
    "@playwright/test": "1.56.1",
    "@tailwindcss/postcss": "4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vercel/git-hooks": "^1.0.0",
    "@vitejs/plugin-react": "4.5.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "28.0.0",
    "lint-staged": "^15.2.2",
    "playwright": "1.56.1",
    "playwright-core": "1.56.1",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.2",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
